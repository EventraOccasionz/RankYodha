rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. Catch-all Safety Net: Deny all access by default
    match /{document=**} {
      allow read, write: if false;
    }

    // --- REUSABLE SECURITY PRIMITIVES & HELPERS ---
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isValidId(id) {
      return id is string && id.size() <= 128;
    }
    
    function incoming() {
      return request.resource.data;
    }
    
    function existing() {
      return resource.data;
    }
    
    function isAdmin() {
      return isSignedIn() && (
        (request.auth.token != null && (
          (request.auth.token.admin == true) ||
          ('email' in request.auth.token && (
            request.auth.token.email == "admin@eliteprep.com" ||
            request.auth.token.email == "rahul@eliteprep.com" ||
            request.auth.token.email == "ayusharora408@gmail.com" ||
            request.auth.token.email == "ddg27874@gmail.com"
          ))
        )) ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    // --- ENTITY SPECIFIC SCHEMAS & VALIDATION BLUEPRINTS ---

    // Blueprint Validation for Admin Entity
    function isValidAdmin(data) {
      return data.keys().hasAll(['userId', 'email', 'createdAt']) &&
             data.userId is string && data.userId.size() <= 128 &&
             data.email is string && data.email.size() <= 256;
    }

    // Blueprint Validation for Profile Entity
    function isValidProfile(data) {
      return data.keys().hasAll(['userId', 'name', 'examCategory', 'avatarUrl', 'totalTests', 'averageAccuracy', 'streakDays', 'predictedRank', 'updatedAt']) &&
             data.userId is string && data.userId.size() <= 128 &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.examCategory is string && data.examCategory.size() <= 50 &&
             data.avatarUrl is string && data.avatarUrl.size() <= 200 &&
             data.totalTests is int && data.totalTests >= 0 &&
             (data.averageAccuracy is int || data.averageAccuracy is float) && data.averageAccuracy >= 0.0 && data.averageAccuracy <= 100.0 &&
             data.streakDays is int && data.streakDays >= 0 &&
             data.predictedRank is int && data.predictedRank >= 0;
    }

    // Blueprint Validation for PrivateInfo Entity
    function isValidPrivateInfo(data) {
      return data.email is string && data.email.size() <= 256 &&
             data.tier is string && (data.tier == 'free' || data.tier == 'premium') &&
             data.createdAt is string &&
             (!data.keys().hasAll(['purchasedSeries']) || data.purchasedSeries is list) &&
             (!data.keys().hasAll(['purchasedTestIds']) || data.purchasedTestIds is list);
    }

    // Blueprint Validation for MockTest Entity
    function isValidMockTest(data) {
      return data.keys().hasAll(['testId', 'title', 'category', 'questionsCount', 'durationMinutes', 'difficulty', 'questions']) &&
             data.testId is string && data.testId.size() <= 128 &&
             data.title is string && data.title.size() <= 500 &&
             data.category is string && data.category.size() <= 100 &&
             data.questionsCount is int &&
             data.durationMinutes is int &&
             data.difficulty is string &&
             data.questions is list &&
             (!data.keys().hasAll(['createdAt']) || data.createdAt is string);
    }

    // Blueprint Validation for UserAttempt Entity
    function isValidUserAttempt(data) {
      return data.keys().hasAll(['attemptId', 'userId', 'testId', 'testTitle', 'category', 'scoreSecured', 'maxScorePossible', 'accuracyPercent', 'timeSpentSeconds', 'takenAt', 'answers']) &&
             data.attemptId is string && data.attemptId.size() <= 128 &&
             data.userId is string && data.userId.size() <= 128 &&
             data.testId is string && data.testId.size() <= 128 &&
             data.testTitle is string && data.testTitle.size() <= 200 &&
             data.category is string && data.category.size() <= 50 &&
             (data.scoreSecured is int || data.scoreSecured is float) && data.scoreSecured >= 0 &&
             data.maxScorePossible is int && data.maxScorePossible >= 0 &&
             (data.accuracyPercent is int || data.accuracyPercent is float) && data.accuracyPercent >= 0.0 && data.accuracyPercent <= 100.0 &&
             data.timeSpentSeconds is int && data.timeSpentSeconds >= 0 &&
             data.answers is list;
    }

    // Blueprint Validation for PrepVideo Entity
    function isValidPrepVideo(data) {
      return data.keys().hasAll(['videoId', 'title', 'videoUrl']) &&
             data.videoId is string && data.videoId.size() <= 128 &&
             data.title is string && data.title.size() <= 1000 &&
             data.videoUrl is string && data.videoUrl.size() <= 2000;
    }

    // Blueprint Validation for DeletedAsset Entity
    function isValidDeletedAsset(data) {
      return data.keys().hasAll(['deleted', 'deletedAt']) &&
             (data.deleted == true || data.deleted == false) &&
             data.deletedAt is string && data.deletedAt.size() <= 200;
    }

    // Blueprint Validation for ActivityLog Entity
    function isValidActivityLog(data) {
      return data.keys().hasAll(['logId', 'userName', 'type', 'detail', 'value', 'timestamp']) &&
             data.logId is string && data.logId.size() <= 128 &&
             data.userName is string && data.userName.size() <= 256 &&
             data.type is string && data.type.size() <= 128 &&
             data.detail is string && data.detail.size() <= 1000 &&
             (data.value is int || data.value is float) &&
             data.timestamp is string && data.timestamp.size() <= 128;
    }

    // Blueprint Validation for GeminiApiKey Entity
    function isValidGeminiApiKey(data) {
      return data.keys().hasAll(['apiKey']) &&
             data.apiKey is string && data.apiKey.size() > 0 && data.apiKey.size() <= 256 &&
             (!data.keys().hasAll(['updatedAt']) || data.updatedAt is string);
    }

    // Blueprint Validation for Payment Entity
    function isValidPayment(data) {
      return data.keys().hasAll(['paymentId', 'userId', 'userName', 'amount', 'status', 'orderId', 'plan', 'timestamp']) &&
             data.paymentId is string && data.paymentId.size() <= 128 &&
             data.userId is string && data.userId.size() <= 128 &&
             data.userName is string && data.userName.size() <= 256 &&
             (data.amount is int || data.amount is float) &&
             data.status in ['captured', 'failed', 'refunded'] &&
             data.orderId is string && data.orderId.size() <= 256 &&
             data.plan is string && data.plan.size() <= 256 &&
             data.timestamp is string && data.timestamp.size() <= 128;
    }

    // Blueprint Validation for DashboardMetrics Entity
    function isValidDashboardMetrics(data) {
      return data.keys().hasAll(['id', 'totalUsers', 'totalSales', 'gatewayHealth', 'gatewayLatency', 'lastUpdated']) &&
             data.id is string && data.id.size() <= 128 &&
             data.totalUsers is int &&
             (data.totalSales is int || data.totalSales is float) &&
             data.gatewayHealth is string && data.gatewayHealth.size() <= 128 &&
             data.gatewayLatency is int &&
             data.lastUpdated is string && data.lastUpdated.size() <= 128;
    }

    // --- FIRESTORE path rules matching definitions ---

    // 0. Manual System Administration Rules & Admin Profiles
    match /admins/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId) && isValidId(userId) && (isValidAdmin(incoming()) || isValidProfile(incoming()));
      allow update: if (isOwner(userId) || isAdmin()) && isValidId(userId) && (isValidAdmin(incoming()) || isValidProfile(incoming()));
      allow delete: if isAdmin();
    }

    // 0b. Private details split schema rules for admins
    match /admins/{userId}/private/info {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidId(userId) && isValidPrivateInfo(incoming());
      allow update: if (isOwner(userId) || isAdmin()) && isValidId(userId) &&
                      incoming().email is string && incoming().email.size() <= 256 &&
                      incoming().tier is string && (incoming().tier == 'free' || incoming().tier == 'premium') &&
                      incoming().createdAt == existing().createdAt &&
                      incoming().diff(existing()).affectedKeys().hasOnly(['email', 'tier', 'planExpiresAt', 'purchasedSeries', 'purchasedTestIds']);
      allow delete: if isAdmin();
    }

    // 0c. Secure Admin Gemini API key BYOK Storage - STRICTLY owner-only read/write permissions
    match /admins/{userId}/private/geminiKey {
      allow read, delete: if isOwner(userId) && isValidId(userId);
      allow create, update: if isOwner(userId) && isValidId(userId) && isValidGeminiApiKey(incoming());
    }

    // 1. Users (Normal Student Profiles) Rules
    match /users/{userId} {
      allow read: if isSignedIn(); // Allow listing for Leaderboard comparison
      allow create: if isOwner(userId) && isValidId(userId) && isValidProfile(incoming()) && incoming().userId == request.auth.uid;
      allow update: if isOwner(userId) && isValidId(userId) && isValidProfile(incoming()) && incoming().userId == existing().userId &&
                      incoming().diff(existing()).affectedKeys().hasOnly(['name', 'examCategory', 'avatarUrl', 'totalTests', 'averageAccuracy', 'averagePercentile', 'streakDays', 'predictedRank', 'updatedAt']);
      allow delete: if isAdmin();
    }

    // 2. Private details split schema rules for normal users
    match /users/{userId}/private/info {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidId(userId) && isValidPrivateInfo(incoming());
      allow update: if (isOwner(userId) || isAdmin()) && isValidId(userId) &&
                      incoming().email is string && incoming().email.size() <= 256 &&
                      incoming().tier is string && (incoming().tier == 'free' || incoming().tier == 'premium') &&
                      incoming().createdAt == existing().createdAt &&
                      incoming().diff(existing()).affectedKeys().hasOnly(['email', 'tier', 'planExpiresAt', 'purchasedSeries', 'purchasedTestIds']);
      allow delete: if isAdmin();
    }
    
    // 2c. Secure Personal Gemini API key BYOK Storage - STRICTLY owner-only read/write permissions
    match /users/{userId}/private/geminiKey {
      allow read, delete: if isOwner(userId) && isValidId(userId);
      allow create, update: if isOwner(userId) && isValidId(userId) && isValidGeminiApiKey(incoming());
    }

    // 3. Mock Examination tests database rules
    match /mockTests/{testId} {
      allow read: if isSignedIn();
      allow create: if isAdmin() && isValidId(testId) && isValidMockTest(incoming());
      allow update: if isAdmin() && isValidId(testId) && isValidMockTest(incoming());
      allow delete: if isAdmin();
    }

    // 4. Detailed history log attempts subcollections
    match /users/{userId}/attempts/{attemptId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidId(userId) && isValidId(attemptId) &&
                      isValidUserAttempt(incoming()) && incoming().userId == request.auth.uid;
      allow update: if isOwner(userId) && isValidId(userId) && isValidId(attemptId) &&
                      isValidUserAttempt(incoming()) && incoming().userId == existing().userId &&
                      incoming().takenAt == existing().takenAt &&
                      incoming().diff(existing()).affectedKeys().hasOnly(['scoreSecured', 'accuracyPercent', 'timeSpentSeconds', 'answers']);
      allow delete: if isAdmin();
    }

    // 5. Prep videos database rules
    match /prepVideos/{videoId} {
      allow read: if true;
      allow create: if isAdmin() && isValidId(videoId) && isValidPrepVideo(incoming());
      allow update: if isAdmin() && isValidId(videoId) && isValidPrepVideo(incoming());
      allow delete: if isAdmin();
    }

    // 6. Deleted assets reference rules
    match /deletedAssets/{assetId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidId(assetId) && isValidDeletedAsset(incoming());
      allow delete: if isAdmin();
    }

    // 7. Live Activity logs rules
    match /activityLogs/{logId} {
      allow create: if isValidId(logId) && isValidActivityLog(incoming());
      allow read, update, delete: if isAdmin();
    }

    // 8. Secure Payment transactions tracking
    match /payments/{paymentId} {
      allow create: if isValidId(paymentId) && isValidPayment(incoming());
      allow read, delete: if isAdmin() || (isSignedIn() && request.auth.uid == resource.data.userId);
      allow update: if isAdmin();
    }

    // 9. Centralized metrics
    match /dashboard/{id} {
      allow read: if isAdmin();
      allow create, update: if isAdmin() && isValidId(id) && isValidDashboardMetrics(incoming());
      allow delete: if isAdmin();
    }

    // 10. Centralized dashboard stats mapping
    match /dashboardStats/{id} {
      allow read: if isAdmin();
      allow create, update: if isAdmin() && isValidId(id) && isValidDashboardMetrics(incoming());
      allow delete: if isAdmin();
    }
  }
}
